msgid "Mail Blast"
msgstr "Correo Masivo"

msgid "Send bulk email"
msgstr "Envío masivo de correo"

msgid "Compose message"
msgstr "Redactar mensaje"

msgid "Subject"
msgstr "Asunto"

msgid "Message body"
msgstr "Cuerpo del mensaje"

msgid "Footer"
msgstr "Pie de página"

msgid "Attachments"
msgstr "Archivos adjuntos"

msgid "Only file types allowed by GLPI are accepted"
msgstr "Solo se aceptan tipos de archivo permitidos por GLPI"

msgid "View allowed file types"
msgstr "Ver tipos de archivo permitidos"

msgid "Drag & drop files here or"
msgstr "Arrastra y suelta archivos aquí o"

msgid "browse"
msgstr "seleccionar"

msgid "user@company.com"
msgstr "usuario@empresa.com"

msgid "Remove"
msgstr "Eliminar"

msgid "B"
msgstr "B"

msgid "KB"
msgstr "KB"

msgid "MB"
msgstr "MB"

msgid "Test email"
msgstr "Correo de prueba"

msgid "Send to my address (administrator)"
msgstr "Enviar a mi dirección (administrador)"

msgid "Send to a specific address"
msgstr "Enviar a una dirección específica"

msgid "Test address"
msgstr "Dirección de prueba"

msgid "Send test email"
msgstr "Enviar correo de prueba"

msgid "Mass mailing"
msgstr "Envío masivo"

msgid "Active users with registered email"
msgstr "Usuarios activos con correo registrado"

msgid "No active users with registered email found"
msgstr "No se encontraron usuarios activos con correo registrado"

msgid "Send to all users"
msgstr "Enviar a todos los usuarios"

msgid "Subject is required"
msgstr "El asunto es obligatorio"

msgid "Body is required"
msgstr "El cuerpo del mensaje es obligatorio"

msgid "Test address is required"
msgstr "La dirección de prueba es obligatoria"

msgid "No email found for your account"
msgstr "No se encontró correo electrónico para tu cuenta"

msgid "Test sent successfully"
msgstr "Prueba enviada correctamente"

msgid "Test failed"
msgstr "Error al enviar la prueba"

msgid "Attachment rejected"
msgstr "Archivo rechazado"

msgid "Invalid address"
msgstr "Dirección inválida"

msgid "Upload error code %d"
msgstr "Error de carga, código %d"

msgid "%1$d email(s) sent to %2$d recipient(s)"
msgstr "%1$d correo(s) enviado(s) a %2$d destinatario(s)"

msgid "%1$d error(s) occurred"
msgstr "Se produjeron %1$d error(es)"

msgid "%1$s: MIME type %2$s is not allowed by GLPI"
msgstr "%1$s: el tipo MIME %2$s no está permitido por GLPI"


msgid "Sending emails"
msgstr "Enviando correos"

msgid "Progress"
msgstr "Progreso"

msgid "Sent"
msgstr "Enviados"

msgid "Errors"
msgstr "Errores"

msgid "Pending"
msgstr "Pendientes"

msgid "Elapsed"
msgstr "Tiempo transcurrido"

msgid "Failed addresses"
msgstr "Direcciones fallidas"

msgid "Close"
msgstr "Cerrar"


msgid "Attachment warning"
msgstr "Advertencia de adjunto"

msgid "Sending…"
msgstr "Enviando…"

msgid "Network error"
msgstr "Error de red"

msgid "Initialization error"
msgstr "Error de inicialización"

msgid "Missing send_id"
msgstr "Falta el ID de envío"

msgid "You are about to send an email to"
msgstr "Estás a punto de enviar un correo a"

msgid "This action cannot be undone. Each recipient will receive one email."
msgstr "Esta acción no se puede deshacer. Cada destinatario recibirá un correo."

msgid "Cancel"
msgstr "Cancelar"

msgid "Yes, send now"
msgstr "Sí, enviar ahora"

msgid "Cancel sending? Emails already sent will not be recalled."
msgstr "Cancelar el envío? Los correos ya enviados no se podrán recuperar."

msgid "Cancelling…"
msgstr "Cancelando…"

msgid "Sending cancelled."
msgstr "Envío cancelado."

msgid "Bad server response"
msgstr "Respuesta inválida del servidor"

msgid "Server error"
msgstr "Error del servidor"

msgid "Could not start sending"
msgstr "No se pudo iniciar el envío"

msgid "Batch failed"
msgstr "Fallo en el lote"

msgid "Plain text. Bold, italic and underline are supported."
msgstr "Texto plano. Se admiten negrita, cursiva y subrayado."

msgid "Bold"
msgstr "Negrita"

msgid "Italic"
msgstr "Cursiva"

msgid "Underline"
msgstr "Subrayado"

msgid "user@company.com, other@company.com"
msgstr "usuario@empresa.com, otro@empresa.com"

msgid "Separate multiple addresses with commas. Maximum 5 addresses."
msgstr "Separa varias direcciones con comas. Máximo 5 direcciones."

msgid "Mail Blast — Configuration"
msgstr "Mail Blast — Configuración"

msgid "Configuration"
msgstr "Configuración"

msgid "Settings saved successfully."
msgstr "Configuración guardada correctamente."

msgid "Batch size"
msgstr "Tamaño de lote"

msgid "Delay between batches (ms)"
msgstr "Retraso entre lotes (ms)"

msgid "Maximum total attachment size (MB)"
msgstr "Tamaño máximo total de adjuntos (MB)"

msgid "Number of emails sent per batch (1–100). Default: 15. Lower values reduce SMTP load; higher values speed up sending."
msgstr "Número de correos enviados por lote (1–100). Predeterminado: 15. Valores más bajos reducen la carga SMTP; valores más altos aceleran el envío."

msgid "Milliseconds to wait between batches (0–5000). Default: 120. Increase this if your SMTP server enforces rate limits."
msgstr "Milisegundos de espera entre lotes (0–5000). Predeterminado: 120. Auméntalo si tu servidor SMTP aplica límites de velocidad."

msgid "Maximum combined size of all attached files (1–100 MB). Default: 15 MB. Files exceeding this limit will be rejected in the browser before upload."
msgstr "Tamaño combinado máximo de todos los archivos adjuntos (1–100 MB). Predeterminado: 15 MB. Los archivos que superen este límite serán rechazados en el navegador."

msgid "Batch size must be between 1 and 100."
msgstr "El tamaño de lote debe estar entre 1 y 100."

msgid "Batch delay must be between 0 and 5000 ms."
msgstr "El retraso entre lotes debe estar entre 0 y 5000 ms."

msgid "Maximum attachment size must be between 1 and 100 MB."
msgstr "El tamaño máximo de adjuntos debe estar entre 1 y 100 MB."

msgid "Attachment size limit exceeded (%s MB max). File not added: %s"
msgstr "Límite de tamaño de adjuntos superado (%s MB máx.). Archivo no agregado: %s"

msgid "Back to Mail Blast"
msgstr "Volver a Mail Blast"

msgid "Sending"
msgstr "Envío"
