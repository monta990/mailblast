msgstr "Kursiv"

msgid "Underline"
msgstr "Unterstrichen"

msgid "user@company.com, other@company.com"
msgstr "benutzer@firma.com, anderer@firma.com"

msgid "Separate multiple addresses with commas. Maximum 5 addresses."
msgstr "Trennen Sie mehrere Adressen durch Kommas. Maximal 5 Adressen."

