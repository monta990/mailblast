msgstr "Konfiguration"

msgid "Settings saved successfully."
msgstr "Einstellungen erfolgreich gespeichert."

msgid "Batch size"
msgstr "Losgröße"

msgid "Delay between batches (ms)"
msgstr "Verzögerung zwischen Losen (ms)"

msgid "Maximum total attachment size (MB)"
msgstr "Maximale Gesamtgröße der Anhänge (MB)"

msgid "Number of emails sent per batch (1–100). Default: 15. Lower values reduce SMTP load; higher values speed up sending."
msgstr "Anzahl der E-Mails pro Los (1–100). Standard: 15. Niedrigere Werte reduzieren die SMTP-Last."

msgid "Milliseconds to wait between batches (0–5000). Default: 120. Increase this if your SMTP server enforces rate limits."
msgstr "Millisekunden Wartezeit zwischen Losen (0–5000). Standard: 120. Erhöhen Sie diesen Wert wenn Ihr SMTP-Server Ratenlimits erzwingt."

msgid "Maximum combined size of all attached files (1–100 MB). Default: 15 MB. Files exceeding this limit will be rejected in the browser before upload."
msgstr "Maximale Gesamtgröße aller Anhänge (1–100 MB). Standard: 15 MB. Dateien über diesem Limit werden im Browser abgelehnt."

msgid "Batch size must be between 1 and 100."
msgstr "Die Losgröße muss zwischen 1 und 100 liegen."

msgid "Batch delay must be between 0 and 5000 ms."
msgstr "Die Losverzögerung muss zwischen 0 und 5000 ms liegen."

msgid "Maximum attachment size must be between 1 and 100 MB."
msgstr "Die maximale Anhangsgröße muss zwischen 1 und 100 MB liegen."

msgid "Attachment size limit exceeded (%s MB max). File not added: %s"
msgstr "Anhangsgröße überschritten (%s MB max). Datei nicht hinzugefügt: %s"

msgid "Back to Mail Blast"
msgstr "Zurück zu Mail Blast"

